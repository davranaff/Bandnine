# Infra (docker-compose)
API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
POSTGRES_DB=ielts
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# App
APP_NAME=IELTS FastAPI API
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1

SECRET_KEY=change-this-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
CONFIRM_TOKEN_EXPIRE_HOURS=24
RESET_TOKEN_EXPIRE_HOURS=1

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ielts
REDIS_URL=redis://redis:6379/0

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@example.com

FRONTEND_BASE_URL=http://localhost:3000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

RATE_LIMIT_SIGN_IN=10
RATE_LIMIT_RESET=5
RATE_LIMIT_WINDOW_SECONDS=60

EXPOSE_DEBUG_TOKENS=false

# Tests (SQLite only)
TEST_DATABASE_URL=sqlite+aiosqlite:///./backend/test.db
